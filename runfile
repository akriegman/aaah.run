#!/bin/bash

function pub {
  jj b m main
  jj commit -m "${*:-publish}"
  jj git push
}

function run {
  cd public && python -m http.server
}

#=== notion sync ===#

set -a; source .env; set +a

function notion {
  curl -sf "https://api.notion.com/v1/$1" \
    -H "Authorization: Bearer $NTN_TOKEN" \
    -H "Notion-Version: 2026-03-11"
}

function pull {
  local path="$1"
  if [ -z "$path" ]; then
    echo "Usage: pull <path/name>"
    return 1
  fi

  IFS='/' read -ra segments <<< "$path"
  local title="${segments[${#segments[@]}-1]}"

  # Navigate Notion page hierarchy to find the page
  local id="$NTN_ROOT"
  for seg in "${segments[@]}"; do
    local children
    children=$(notion "blocks/$id/children") || return 1
    id=$(echo "$children" | jq -r --arg seg "$seg" '.results[] | select(.type == "child_page" and .child_page.title == $seg) | .id')
    if [ -z "$id" ]; then
      echo "Not found: $seg"
      echo "$children" | jq -r '.results[] | select(.type == "child_page") | .child_page.title'
      return 1
    fi
  done

  # Fetch created date
  local created
  created=$(notion "pages/$id" | jq -r '.created_time')
  local date_fmt
  date_fmt=$(date -j -f "%Y-%m-%dT%H:%M:%S" "${created%%.*}" "+%-d %B %Y" 2>/dev/null)

  # Fetch markdown via notion-to-md and convert to HTML
  local body
  body=$(deno run --allow-env --allow-net -q - <<'DENO_EOF' "$id" | tee /dev/tty | multimarkdown
import { Client } from "npm:@notionhq/client";
import { NotionToMarkdown } from "npm:notion-to-md";
const n2m = new NotionToMarkdown({ notionClient: new Client({ auth: Deno.env.get("NTN_TOKEN") }) });
const blocks = await n2m.pageToMarkdown(Deno.args[0]);
Deno.stdout.writeSync(new TextEncoder().encode(n2m.toMarkdownString(blocks).parent));
DENO_EOF
  )

  # Build breadcrumb
  local breadcrumb='<a href=/>Aaron Kriegman</a> /'
  for ((i=0; i<${#segments[@]}-1; i++)); do
    local href="/"
    for ((j=0; j<=i; j++)); do href+="${segments[$j]}/"; done
    breadcrumb+=$'\n        '"<a href=\"$href\">${segments[$i]}</a> /"
  done

  # Output path: name/index.html if name/ exists, else name.html
  local outfile
  if [ -d "public/$path" ]; then
    outfile="public/$path/index.html"
  else
    local dir="public/${path%/*}"
    [ "$dir" != "public/$path" ] && mkdir -p "$dir"
    outfile="public/$path.html"
  fi

  BREADCRUMB="$breadcrumb" TITLE="$title" DATE="$date_fmt" BODY="$body" \
    gomplate -f template.html -o "$outfile"
  echo "Wrote $outfile"
}
